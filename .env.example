# VARA Resident Platform — env vars

# Anthropic — claude-sonnet-4-5 powers daily intention + concierge triage.
# If unset, the app uses curated fallback copy. Demo works without this set.
ANTHROPIC_API_KEY=

# Supabase — not used in MVP, wired for Phase B.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — not used in MVP, wired for Phase B (Calendar RSVP payments).
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend — not used in MVP, wired for Phase B (transactional email).
RESEND_API_KEY=
